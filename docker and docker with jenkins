### S6

Update all installed plugins.

Make sure these plugins are installed:

* CloudBees Docker Custom Build Environment
* Docker
* Docker Pipelines
* Docker Compose Build Steps

Because DevOps without plugins is just suffering manually with extra steps.

---

### S7

Create a new item with name `Doc2` and select **Pipeline** item type.

---

### S8

Add this pipeline script:

```groovy
pipeline
{
    agent any

    environment
    {
        dockerImage = "ayush05/test.2"
        registry = "ayush05/test.2"
        registryCredential = "jenkin_docker_token"
    }

    stages
    {
        stage('Checkout')
        {
            steps
            {
                checkout scmGit(
                    branches: [[name: '*/main']],
                    extensions: [],
                    userRemoteConfigs: [[
                        url: 'https://github.com/AyushThanthri/dockerprog.git'
                    ]]
                )
            }
        }

        stage('Build Docker Image')
        {
            steps
            {
                script
                {
                    dockerImage = docker.build(registry)
                }
            }
        }
    }
}
```

